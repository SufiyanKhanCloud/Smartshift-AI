# Copy this file to .env and fill in values before starting the server.
# Never commit .env to version control.

# Required in production — a long random string for Flask session signing.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SMARTSHIFT_SECRET=change-me-to-a-long-random-string

# Set to "1" for development (enables auto-reload, debug toolbar, relaxed CSP).
# Leave unset or "0" in production.
FLASK_DEBUG=1

# Optional: override where trained model .pkl files are stored.
# Defaults to model/_store/ relative to the project root.
# MODEL_DIR=/path/to/model/store

# --- Supabase (authentication + database) ---
# From Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-public-key...
# From Project Settings -> API -> JWT Keys -> JWT Secret (legacy HS256 secret)
SUPABASE_JWT_SECRET=your-jwt-secret
# For projects on the newer ASYMMETRIC (ES256) signing key, pin the PUBLIC key
# here so the backend verifies tokens offline. Get it from:
#   Project Settings -> API -> JWT Keys -> (your ES256 key) -> Public key (PEM),
# or the JWKS at {SUPABASE_URL}/auth/v1/.well-known/jwks.json. Put it on ONE line
# using \n for the line breaks. Leave unset if your project uses only HS256.
# SUPABASE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMFk...\n-----END PUBLIC KEY-----"
# OPTIONAL — only needed to enable full "Delete Account" (admin API). Keep secret!
# From Project Settings -> API -> service_role key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
